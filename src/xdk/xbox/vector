#pragma once

#include <memory>
#include <types.h>

namespace std {
    template <typename T, typename Alloc>
    class _Vector_val {
    protected:
        T *_Myfirst;
        T *_Mylast;
        T *_Myend;
        Alloc _Alval;
    };

    template <typename T, typename Alloc = allocator<T> >
    class vector : public _Vector_val<T, Alloc> {
    public:
        typedef T &reference;
        typedef const T &const_reference;

        uint size(void) const { return (this->_Mylast - this->_Myfirst) / sizeof(T); }

        const_reference operator[](uint idx) const { return this->_Myfirst[idx]; }
        reference operator[](uint idx) { return this->_Myfirst[idx]; }

        void push_back(const_reference ref) {}

        ~vector() { _Tidy(); }

    protected:
        void _Tidy(void);
    };
}
